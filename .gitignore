# Python bytecode - auto-generated by Python when running code, not human-written
__pycache__/
*.py[cod]

# Package distribution and build artifacts - generated by pip/setuptools when packaging
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments - local Python environment with dependencies, not part of the code
.venv/
venv/
env/

# Jupyter checkpoints - auto-generated by Jupyter notebooks, not part of the code
.ipynb_checkpoints/

# Environment variables - may contain secrets, API keys, credentials, never commit these
.env
.env.*

# IDE settings - personal editor preferences, irrelevant to other developers
.vscode/
.idea/

# OS auto-generated files - created by macOS (.DS_Store) and Windows (Thumbs.db), irrelevant to the project
.DS_Store
Thumbs.db

# Original assignment brief - not part of the deliverable
exercise_context.odt

# Personal exploration notebook - not part of the deliverable
exploration.ipynb
